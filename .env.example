# =============================================================================
# Environment variable template. Copy to .env and fill in values.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (§10)
# -----------------------------------------------------------------------------
POSTGRES_USER=defi
POSTGRES_PASSWORD=defi
POSTGRES_DB=defi_vault
# Backend connection string (override for local; in Docker this is built from POSTGRES_*)
DATABASE_URL=postgresql+asyncpg://defi:defi@localhost:5432/defi_vault

# Redis (Celery broker + cache)
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Auth (Supabase bridge, §19) — see docs/supabase-setup.md for setup steps
# -----------------------------------------------------------------------------
# Project URL: Dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://your-project.supabase.co
# Anon (public) key: Dashboard → Project Settings → API → anon public key
SUPABASE_ANON_KEY=your-anon-key
# JWT Secret: Dashboard → Project Settings → API → JWT Secret (backend only; never expose)
SUPABASE_JWT_SECRET=your-jwt-secret
# Service role key: Dashboard → Project Settings → API → service_role secret (backend only; never expose)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Frontend-only: same URL and anon key, required for @supabase/supabase-js in Next.js
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# -----------------------------------------------------------------------------
# APIs (RPC, data providers, §9 / §20)
# -----------------------------------------------------------------------------
ALCHEMY_API_KEY=
HELIUS_API_KEY=
LIFI_API_KEY=

# AI (Claude via LiteLLM)
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# App (domain, admin alerts)
# -----------------------------------------------------------------------------
DOMAIN=vault.example.com
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
APP_SECRET_KEY=change-me-in-production
ENVIRONMENT=development

# Production SSL (Let's Encrypt)
CERTBOT_EMAIL=admin@example.com

# -----------------------------------------------------------------------------
# Budgets (admin cost monitoring, §20)
# -----------------------------------------------------------------------------
MONTHLY_BUDGET_USD=100
CLAUDE_BUDGET_USD=50
VPS_COST_USD=14
